{
  "name": "subzero-md",
  "version": "7.0.0",
  "type": "module",
  "description": "SUBZERO-MD V7 — Advanced WhatsApp Bot by Mr Frank OFC 🇿🇼",
  "author": "Mr Frank OFC (Darrell Mucheri)",
  "license": "MIT",
  "main": "index.js",

  "directories": {
    "assets": "assets",
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrfrankofcc/subzero-md.git"
  },
  "bugs": {
    "url": "https://github.com/mrfrankofcc/subzero-md/issues"
  },
  "homepage": "https://github.com/mrfrankofcc/subzero-md#readme",
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/mrfr8nk"
  },

  "engines": {
    "node": ">=20.0.0"
  },

  "keywords": [
    "subzero-md",
    "whatsapp-bot",
    "baileys",
    "multi-device",
    "whatsapp-automation",
    "nodejs",
    "mr-frank-ofc",
    "subzero",
    "sticker-bot"
  ],

  "scripts": {
    "start": "node index.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 index.js",
    "start:fresh": "node reset-data.js && node index.js",

    "dev": "nodemon --watch . --ext js index.js",

    "pm2": "pm2 start index.js --name subzero-md",
    "pm2:stop": "pm2 stop subzero-md",
    "pm2:restart": "pm2 restart subzero-md",
    "pm2:logs": "pm2 logs subzero-md",
    "pm2:monit": "pm2 monit",

    "setup": "node reset-data.js",
    "reset-data": "node reset-data.js",
    "reset-session": "node -e \"import('fs').then(f=>f.default.rmSync('./session',{recursive:true,force:true})).then(()=>console.log('Session cleared!'))\"",

    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",

    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",

    "audit": "npm audit --omit=dev"
  },

  "dependencies": {
    "@adiwajshing/keyed-db": "latest",
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@hapi/boom": "^10.0.1",
    "@octokit/rest": "latest",
    "@vitalets/google-translate-api": "^9.2.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",

    "acrcloud": "^1.4.0",
    "adm-zip": "^0.5.16",
    "api-dylux": "latest",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "*",

    "axios": "^1.8.4",
    "better-sqlite3": "^12.5.0",
    "btch-downloader": "^2.2.9",

    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "crypto-digest-sync": "^1.0.0",
    "crypto-js": "latest",

    "dotenv": "^16.4.5",
    "express": "^4.22.1",

    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",

    "file-type": "^19.6.0",
    "file_size_url": "1.0.4",
    "form-data": "^4.0.1",
    "fs-extra": "^11.3.0",

    "gifted-btns": "^1.0.2",
    "google-tts-api": "^2.0.2",
    "gspeak": "^0.0.3",

    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",

    "libphonenumber-js": "^1.11.18",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",

    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",

    "node-cache": "^5.1.2",
    "node-fetch": "^2.6.1",
    "node-webpmux": "^3.1.7",

    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.16.0",

    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",

    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "qrcode-reader": "^1.0.4",
    "qrcode-terminal": "^0.12.0",

    "ruhend-scraper": "^9.0.8",

    "sequelize": "^6.37.6",
    "sharp": "^0.34.0",
    "simple-git": "*",
    "sqlite3": "^5.1.7",

    "syntax-error": "^1.4.0",
    "unzipper": "latest",

    "wa-sticker-formatter": "^4.4.4",
    "wa_set_pkg": "1.0.5",

    "yt-search": "^2.12.1"
  },

  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "nodemon": "^3.1.14",
    "pm2": "^5.4.3",
    "vitest": "^4.0.18"
  },

  "overrides": {
    "minimatch": "^10.2.1",
    "yargs-parser": "^21.1.1"
  }
}
